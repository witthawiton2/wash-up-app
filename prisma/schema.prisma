generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String
  role      String   @default("staff") // admin, staff, driver
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id           Int      @id @default(autoincrement())
  customerCode String?
  name         String
  phone      String?
  address    String?
  package    String?  @default("Basic")
  endDate    DateTime?
  remaining  Int      @default(0)
  lineUserId String?  @unique
  lineId     String?
  email      String?
  status       String   @default("approved")
  renewPending Boolean  @default(false)
  renewSlipUrl String?
  createdAt    DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]
  payments   Payment[]
  pushSubscriptions PushSubscription[]

  @@index([phone])
}

model Order {
  id            Int      @id @default(autoincrement())
  orderId       String   @unique
  customerId    Int?
  customer      Customer? @relation(fields: [customerId], references: [id])
  walkInName    String?
  status        String   @default("รอซักรีด")
  totalAmount   Float    @default(0)
  hangersOwned  Int      @default(0)
  hangersBought Int      @default(0)
  discount      Float    @default(0)
  checkPhotos   String?
  note                  String?
  requestedDeliveryDate DateTime?
  deliveryMethod        String?   // "home" | "self" — the booking method, mirrors the label stored in note
  paymentSlipUrl        String?
  paymentStatus         String   @default("unpaid") // unpaid, pending, paid
  paymentMethod         String?  // cash | qr_promptpay | bank_transfer | other
  paidAt                DateTime?
  orderDate             DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  items         OrderItem[]
  delivery      Delivery?
}

model OrderItem {
  id       Int    @id @default(autoincrement())
  orderId  Int
  order    Order  @relation(fields: [orderId], references: [id])
  itemName String
  quantity Int
  price    Float  @default(0)
  total    Float  @default(0)
}

model Delivery {
  id       Int      @id @default(autoincrement())
  orderId  Int      @unique
  order    Order    @relation(fields: [orderId], references: [id])
  address  String?
  status   String   @default("รอจัดส่ง")
  date     DateTime?
  photoUrl String?
}

model Package {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  totalItems  Int
  validDays   Int
  price       Float
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServiceItem {
  id               Int      @id @default(autoincrement())
  name             String
  nameEn           String?
  price            Float    @default(0)
  category         String   @default("รายการซักอบรีด")
  note             String?
  inPackage        Boolean  @default(false)
  packageDeduction Int      @default(1)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([name, category])
}

model Promotion {
  id        Int      @id @default(autoincrement())
  name      String
  discount  String
  startDate DateTime
  endDate   DateTime
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String   // create_order, edit_order, mark_ready, complete_delivery, approve_customer, renew_package
  user      String?  // username ที่ทำ
  target    String?  // orderId, customerId
  detail    String?  // รายละเอียด
  createdAt DateTime @default(now())
}

model Payment {
  id          Int      @id @default(autoincrement())
  customerId  Int?
  customer    Customer? @relation(fields: [customerId], references: [id])
  type        String   // "order" | "package_renew"
  amount      Float
  method      String?  // cash | qr_promptpay | bank_transfer | other
  slipUrl     String?
  status      String   @default("pending") // pending, confirmed, rejected
  note        String?
  orderId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Stock {
  id           Int      @id @default(autoincrement())
  category     String   // detergent | hangers | packaging | other
  name         String
  unit         String   @default("piece")
  quantity     Float    @default(0)
  reorderLevel Float    @default(0)
  note         String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  movements    StockMovement[]
}

model StockMovement {
  id        Int      @id @default(autoincrement())
  stockId   Int
  stock     Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)
  delta     Float    // +ve = restock, -ve = consume
  note      String?
  createdAt DateTime @default(now())

  @@index([stockId, createdAt])
}

model PushSubscription {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  endpoint   String   @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([customerId])
}

model Settings {
  id              Int      @id @default(1)
  logoUrl         String?
  companyName     String?
  companyPhone    String?
  companyAddress  String?
  lineId          String?
  promptpayId     String?
  receiptHeader   String?
  receiptFooter   String?
  updatedAt       DateTime @updatedAt
}

model BookingSlotCap {
  id        Int      @id @default(autoincrement())
  date      String   @default("") // "" = default (every day) · "YYYY-MM-DD" = override for that date (holidays/peak days)
  time      String   // "9:00" — matches the HH:MM strings in /my slotTimes
  activity  String   // "send" | "receive" — the booking activity this cap limits
  capacity  Int      @default(0) // 0 = closed for this activity
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, time, activity])
}
