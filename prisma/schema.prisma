generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String
  role      String   @default("staff") // admin, staff, driver
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id           Int      @id @default(autoincrement())
  customerCode String?
  name         String
  phone      String?
  address    String?
  package    String?  @default("Basic")
  endDate    DateTime?
  remaining  Int      @default(0)
  lineUserId String?  @unique
  lineId     String?
  email      String?
  status       String   @default("approved")
  renewPending Boolean  @default(false)
  renewSlipUrl String?
  createdAt    DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]
}

model Order {
  id            Int      @id @default(autoincrement())
  orderId       String   @unique
  customerId    Int?
  customer      Customer? @relation(fields: [customerId], references: [id])
  walkInName    String?
  status        String   @default("รอซักรีด")
  totalAmount   Float    @default(0)
  hangersOwned  Int      @default(0)
  hangersBought Int      @default(0)
  discount      Float    @default(0)
  checkPhotos   String?
  note          String?
  orderDate     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  items         OrderItem[]
  delivery      Delivery?
}

model OrderItem {
  id       Int    @id @default(autoincrement())
  orderId  Int
  order    Order  @relation(fields: [orderId], references: [id])
  itemName String
  quantity Int
  price    Float  @default(0)
  total    Float  @default(0)
}

model Delivery {
  id       Int      @id @default(autoincrement())
  orderId  Int      @unique
  order    Order    @relation(fields: [orderId], references: [id])
  address  String?
  status   String   @default("รอจัดส่ง")
  date     DateTime?
  photoUrl String?
}

model Package {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  totalItems  Int
  validDays   Int
  price       Float
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServiceItem {
  id               Int      @id @default(autoincrement())
  name             String
  price            Float    @default(0)
  category         String   @default("รายการซักอบรีด")
  note             String?
  inPackage        Boolean  @default(false)
  packageDeduction Int      @default(1)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([name, category])
}

model Promotion {
  id        Int      @id @default(autoincrement())
  name      String
  discount  String
  startDate DateTime
  endDate   DateTime
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
